# ============================================
# ZephyrStream - Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# --- Database ---
# SQLite database file path (default works for development)
DATABASE_URL=file:/home/z/my-project/db/custom.db

# --- Authentication ---
# IMPORTANT: Change this to a long random string in production!
# Generate one with: openssl rand -base64 64
JWT_SECRET=change-this-to-a-long-random-secret-string-in-production-please

# --- FFmpeg Paths ---
# Leave as default if FFmpeg is in your PATH
# Otherwise specify the full path to the binaries
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# --- App Configuration ---
# Set to "production" for production deployment
NODE_ENV=development

# --- Optional: Port (default 3000) ---
# PORT=3000

# ============================================
# Notes:
# ============================================
# 1. Google Cloud credentials (clientId/clientSecret) are stored per-channel
#    in the database — no env vars needed for those.
# 2. Each channel manages its own OAuth tokens (refresh tokens are encrypted
#    at rest by the database layer).
# 3. YouTube stream keys are used for actual live streaming (NOT the API)
#    to save Google Cloud API quota.
# 4. The default redirect URI for OAuth is "urn:ietf:wg:oauth:2.0:oob"
#    (Google's out-of-band flow — paste the code manually).
#    If you want to use a web redirect instead, configure it in Google Cloud
#    Console and update src/lib/youtube.ts.
