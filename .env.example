# ============================================
# ZephyrStream - Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# --- Database ---
# SQLite database file path — use ABSOLUTE path to your project folder
# Example: file:/home/ubuntu/ZephyrStream/db/custom.db
DATABASE_URL=file:/home/YOUR_USERNAME/ZephyrStream/db/custom.db

# --- Authentication ---
# IMPORTANT: Generate a random secret! Do NOT use the default value.
# Generate with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-secret-run-openssl-rand-hex-32

# --- Encryption (Optional but recommended) ---
# Used to encrypt OAuth tokens (refreshToken, accessToken, clientSecret)
# at rest in the database. If not set, JWT_SECRET is used as fallback.
# Generate with: openssl rand -hex 32
# IMPORTANT: Changing this key requires re-authorizing all channels
# (old encrypted tokens can't be decrypted with the new key).
# ENCRYPTION_KEY=generate-a-different-random-secret

# --- FFmpeg Paths ---
# Leave as default if FFmpeg is in your PATH
# Otherwise specify the full path to the binaries
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# --- App Configuration ---
# Set to "production" for VPS deployment
NODE_ENV=production

# --- HTTPS (Optional) ---
# Only set to "true" if you use a reverse proxy with SSL (Nginx/Caddy + domain)
# If accessing via http://IP-VPS:3000, leave this commented or set to "false"
# HTTPS=false

# --- Realtime Service CORS (Optional) ---
# Comma-separated list of allowed origins for Socket.io (port 3003)
# Example: http://localhost:3000,http://your-vps-ip:3000
# Leave empty for same-origin only (most secure)
# ALLOWED_ORIGINS=http://localhost:3000

# --- Optional: Port (default 3000) ---
# PORT=3000

# ============================================
# Notes:
# ============================================
# 1. Google Cloud credentials (clientId/clientSecret) are stored per-channel
#    in the database — no env vars needed for those.
# 2. OAuth tokens (accessToken/refreshToken) are stored in plaintext in the
#    SQLite database. Protect the db/custom.db file — do not expose it
#    publicly or commit it to git.
# 3. YouTube stream keys are used for actual live streaming (NOT the API)
#    to save Google Cloud API quota.
# 4. OAuth redirect URI: http://localhost:3000/api/channels/oauth-callback
#    Register this EXACT URL in Google Cloud Console → Credentials →
#    OAuth 2.0 Client ID → Authorized redirect URIs.
#    After Google redirects, copy the full URL from the browser address bar
#    and paste it into the "Exchange Code" dialog in ZephyrStream.
# 5. For HTTP access (no domain/HTTPS), cookies are sent non-secure.
#    For HTTPS access (with domain + SSL), set HTTPS=true to enable secure cookies.
