// ZephyrStream - Web Edition Prisma Schema
// Multi-channel YouTube live streaming management platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  role         String    @default("user") // user | admin
  avatar       String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  channels     Channel[]
  streams      Stream[]
  files        UploadedFile[]
  titles       TitleItem[]
  thumbnails   ThumbnailItem[]
  templates    StreamTemplate[]
  sessions     Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Channel {
  id              String    @id @default(cuid())
  userId          String
  name            String
  description     String?
  youtubeChannelId String?
  youtubeChannelName String?
  // Google Cloud OAuth client credentials (one per channel)
  // Each channel uses its own API/token to create live broadcasts in YouTube Studio
  clientId        String
  clientSecret    String
  refreshToken    String?
  accessToken     String?
  tokenExpiresAt  DateTime?
  status          String    @default("inactive") // active | inactive | error
  lastSyncAt      DateTime?
  // Rotator indexes — persisted across streams so each stream uses the next
  // title/thumbnail in the list. Reset to 0 when shuffle is clicked.
  titleRotatorIndex     Int @default(0)
  thumbnailRotatorIndex Int @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  streams         Stream[]
  files           UploadedFile[]
  titles          TitleItem[]
  thumbnails      ThumbnailItem[]

  @@index([userId])
}

// Per-channel list of stream titles — used by the rotator to vary stream titles
// and avoid YouTube spam detection. Each channel has its own independent list.
model TitleItem {
  id        String   @id @default(cuid())
  userId    String
  channelId String
  title     String
  // Optional emoji to prepend/append (used by the spinner)
  emoji     String?
  // Rotator index — persisted across restarts so we know which title is next
  // -1 means "not yet used"
  sortOrder Int      @default(0)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([channelId])
}

// Per-channel list of thumbnail images — paired with titles for rotation.
// Each thumbnail belongs to exactly one channel.
model ThumbnailItem {
  id           String   @id @default(cuid())
  userId       String
  channelId    String
  name         String
  originalName String
  mimeType     String
  size         Int
  // Local storage path on disk
  storagePath  String
  // Optional: YouTube thumbnail URL once uploaded (cached)
  youtubeUrl   String?
  // Rotator index
  sortOrder    Int      @default(0)
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel      Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([channelId])
}

model Stream {
  id              String    @id @default(cuid())
  userId          String
  channelId       String?
  name            String
  description     String?

  // YouTube live broadcast configuration
  streamKey       String    // YouTube stream key (used by FFmpeg for RTMP — saves API quota)
  rtmpUrl         String    @default("rtmp://a.rtmp.youtube.com/live2")
  broadcastId     String?   // Set when broadcast is created via YouTube API
  streamId        String?   // Bound liveStream id
  broadcastStatus String?   // created | ready | testing | live | complete | revoked
  // Post-live replay privacy: public | unlisted | random_unlisted
  // (live broadcast itself is always public; this controls replay visibility)
  privacyStatus   String    @default("public")
  categoryId      String    @default("22") // People & Blogs
  tags            String?   // Comma-separated
  playlistId      String?
  thumbnailUrl    String?
  alteredContent  Boolean   @default(false) // YouTube "altered/synthetic content" flag

  // === Resolved title & thumbnail — picked at SCHEDULE CREATION time ===
  // (NOT at stream start). This way each scheduled stream has its own
  // pre-assigned title/thumbnail from the rotator, and the rotator
  // index advances when the schedule is created, not when it starts.
  resolvedTitle          String?  // Final title (with spinner emoji applied)
  resolvedThumbnailPath  String?  // Local path to the thumbnail file
  resolvedThumbnailMime  String?  // MIME type for the thumbnail file

  // Video source
  sourceType      String    @default("local") // local | gdrive
  sourcePath      String?   // Local folder path or Google Drive folder id
  sourceFileIds   String?   // JSON array of file IDs (for multi-file)
  shuffle         Boolean   @default(true)
  loopUntilDuration Boolean @default(true)

  // Schedule — duration is randomized between minHours and maxHours
  // startAt is the scheduled start time. When autoCreateSchedule is on,
  // the scheduler auto-starts the stream at startAt, and on end/error
  // creates a new stream for startAt + 24h with the same stream key.
  startAt         DateTime?
  minHours        Float     @default(2.0)  // Minimum stream duration in hours
  maxHours        Float     @default(4.0)  // Maximum stream duration in hours
  autoCreateSchedule Boolean @default(false) // Auto-create next-day schedule on end/error
  autoDeleteAfterMinutes Int @default(30)

  // FFmpeg configuration
  encoder         String    @default("auto") // auto | x264 | nvenc | qsv | amf | videotoolbox
  copyMode        Boolean   @default(false)
  videoBitrate    String    @default("4500k")
  audioBitrate    String    @default("160k")
  resolution      String    @default("1920x1080")
  fps             Int       @default(30)
  preset          String    @default("veryfast")

  // Title spinner (anti-spam)
  spinnerMode     String    @default("off") // off | front | back | both
  spinnerEmojis   String?   // JSON array of emojis

  // Runtime
  status          String    @default("scheduled") // scheduled | preparing | live | stopping | ended | error
  pid             Int?
  startedAt       DateTime?
  endedAt         DateTime?
  lastError       String?
  logFile         String?
  retryCount      Int       @default(0) // FFmpeg auto-restart attempt count (reset on manual start)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel         Channel?  @relation(fields: [channelId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([channelId])
  @@index([status])
}

model UploadedFile {
  id           String   @id @default(cuid())
  userId       String
  channelId    String?  // Optional — when set, file is scoped to this channel only
  name         String
  originalName String
  mimeType     String
  size         Int
  // Storage info
  storageType  String   @default("local") // local | gdrive
  storagePath  String?  // Local path on disk
  gdriveFileId String?  // Google Drive file ID
  // Metadata
  duration     Float?   // In seconds (for video files)
  width        Int?
  height       Int?
  codec        String?
  bitrate      String?
  // Status
  status       String   @default("ready") // uploading | ready | error | deleted
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel      Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([channelId])
  @@index([storageType])
}

model SystemMetric {
  id        String   @id @default(cuid())
  cpuUsage  Float    // Percentage
  cpuCores  Int
  cpuTemp   Float?
  ramTotal  Float    // In GB
  ramUsed   Float
  ramUsage  Float    // Percentage
  diskTotal Float    // In GB
  diskUsed  Float
  diskUsage Float    // Percentage
  netDownload Float  // In Mbps
  netUpload   Float  // In Mbps
  uptime    Float    // In seconds
  loadAvg1  Float
  loadAvg5  Float
  loadAvg15 Float
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  level     String   @default("info") // info | warn | error | success
  category  String   // auth | channel | stream | file | system
  message   String
  details   String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([category])
  @@index([createdAt])
}

// Stream configuration templates — reusable presets for quick stream creation
model StreamTemplate {
  id              String   @id @default(cuid())
  userId          String
  name            String
  description     String?

  // FFmpeg configuration
  encoder         String   @default("auto")
  copyMode        Boolean  @default(false)
  videoBitrate    String   @default("4500k")
  audioBitrate    String   @default("160k")
  resolution      String   @default("1920x1080")
  fps             Int      @default(30)
  preset          String   @default("veryfast")

  // Stream settings
  privacyStatus   String   @default("public")
  categoryId      String   @default("22")
  tags            String?
  playlistId      String?
  alteredContent  Boolean  @default(false)

  // Duration
  minHours        Float    @default(2.0)
  maxHours        Float    @default(4.0)

  // Spinner
  spinnerMode     String   @default("off")
  spinnerEmojis   String?

  // Schedule settings
  autoCreateSchedule Boolean @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
